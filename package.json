{
  "name": "bullet-time",
  "version": "1.0.1",
  "description": "Gantt-style timelines from a bullet list, for Obsidian.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node esbuild.config.mjs test && node test/harness.cjs",
    "deploy": "npm run build && node scripts/deploy.mjs",
    "version": "node scripts/version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "timeline",
    "gantt"
  ],
  "author": "Herve Sliwa",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.5.0",
    "typescript": "^5.4.0"
  }
}
